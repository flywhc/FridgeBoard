# 生产环境持久卷中的 SQLite 数据库路径；请使用容器内绝对路径。
FRIDGEBOARD_DATABASE_URL=sqlite:////data/fridgeboard.db
FRIDGEBOARD_PUBLIC_BASE_URL=https://fridge.flycn.fyi
FRIDGEBOARD_FLYCN_AUTHORIZE_URL=https://app.flycn.fyi/integrations/fridgeboard/authorize
# flycn 容器在同一 Docker 网络中的内部兑换地址，不应使用公网地址。
FRIDGEBOARD_FLYCN_EXCHANGE_URL=http://flycn-app:8000/api/internal/fridgeboard/token
# 与 flycn 的 FRIDGEBOARD_CLIENT_SECRET 一致，只能由部署环境注入。
FRIDGEBOARD_FLYCN_CLIENT_SECRET=replace-with-a-long-random-secret
# 私有 OpenWrt/LAN 部署可设置固定本地所有者 ID，跳过 flycn 登录。仅限受信任局域网，
# 且不要同时配置 flycn SSO 变量。
# FRIDGEBOARD_LOCAL_OWNER_USER_ID=local-household-owner
